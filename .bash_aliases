#!/bin/bash

# Portions stolen from bash-it https://github.com/Bash-it/bash-it

# Change directory
alias cd..='cd ..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

# List
alias sl='ls'
alias la='ls -AF'
alias ll='ls -al'
alias l='ls -a'
alias l1='ls -1'
alias lf='ls -F'
